{
  "name": "clipboard-history",
  "version": "1.0.0",
  "description": "Windows 历史剪贴板管理工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:win": "electron-builder --win portable",
    "build:mac": "electron-builder --mac dmg zip",
    "build:dir:mac": "electron-builder --mac dir",
    "build:all": "electron-builder --mac dmg zip --win portable"
  },
  "build": {
    "appId": "com.clipboard.history",
    "productName": "Clipboard History",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "clipboard-history-windows-v${version}.${ext}",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "artifactName": "clipboard-history-macos-${version}-${arch}.${ext}"
    },
    "portable": {},
    "files": [
      "main.js",
      "index.html",
      "renderer.js",
      "build/**/*",
      "package.json"
    ]
  },
  "keywords": [
    "clipboard",
    "history",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  }
}
